# Set your location for weather
VITE_LAT=37.7749
VITE_LON=-122.4194

# Google Calendar (public calendar recommended)
# API key: create in Google Cloud Console (enable Calendar API)
# Calendar ID: e.g., yourname@gmail.com or a public calendar ID
VITE_GCAL_API_KEY=
VITE_GCAL_CALENDAR_ID=

# Timezone for calendar display (IANA name, e.g. America/New_York, America/Chicago)
VITE_TIMEZONE=

# Google OAuth (required for Google Calendar full sync and Google Photos)
# Client ID + Secret: from Google Cloud Console → OAuth 2.0 Client IDs (Web application)
# GOOGLE_CLIENT_SECRET is server-only — never exposed to the browser
VITE_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Google Photos (optional) — album ID from the shared album URL
VITE_GOOGLE_PHOTOS_ALBUM_ID=

# iCal feed (optional) — server proxies this URL to avoid CORS
GCAL_ICAL_URL=

# Admin PIN — required to open Settings, upload/delete photos, or connect
# Google accounts. The dashboard itself (clock, weather, calendar, photos,
# checking off todos) works without it. Leave blank to disable.
FAM_BAM_ADMIN_PIN=

