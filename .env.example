# Copy this file to .env and fill in your values

# Location for weather (default: San Francisco)
VITE_LAT=37.7749
VITE_LON=-122.4194

# Google Calendar API
# Get your API key from: https://console.cloud.google.com/apis/credentials
# Enable the Google Calendar API in your project
VITE_GCAL_API_KEY=your_api_key_here
VITE_GCAL_CALENDAR_ID=your_email@gmail.com

# Google Photos (optional)
# Get OAuth Client ID from: https://console.cloud.google.com/apis/credentials
# Enable the Google Photos Library API in your project
VITE_GOOGLE_CLIENT_ID=your_client_id_here.apps.googleusercontent.com
VITE_GOOGLE_PHOTOS_ALBUM_ID=your_album_id_here
